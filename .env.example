# Copy to .env and fill in real values. .env is gitignored.

# Required only if you want to run live LLM calls in notebook 4 or
# regenerate outputs/llm_agreement.csv. If unset, the pipeline falls
# back to the cached LA6 predictions and skips live inference.
GROQ_API_KEY=your_groq_api_key_here

# Optional, used by sentence-transformers for BERTopic embeddings if
# you hit Hugging Face rate limits. Most users will not need this.
HF_TOKEN=optional_huggingface_token
